# ============================================================================
# BACKEND ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and update with your actual values
# NEVER commit .env file - it contains sensitive credentials!

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Option 1: Use connection string (recommended for cloud databases)
# DATABASE_URL=mysql://user:password@host:port/database

# Option 2: Use individual variables (traditional)
# Leave DATABASE_URL empty to use these:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hr_management_system

# ============================================================================
# JWT CONFIGURATION
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_REFRESH_SECRET=your-refresh-token-secret-key-min-32-chars

# Token expiration
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================================
# EMAIL CONFIGURATION (Resend)
# ============================================================================
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=3000
NODE_ENV=development

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
APP_URL=http://localhost:3000
APP_NAME=HR Management System
COMPANY_NAME=Your Company

# ============================================================================
# REDIS CONFIGURATION (Optional)
# ============================================================================
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# ============================================================================
# CPANEL CONFIGURATION (if using cPanel deployment)
# ============================================================================
CPANEL_HOST=your_cpanel_host
CPANEL_USERNAME=your_cpanel_username
CPANEL_API_TOKEN=your_cpanel_api_token
CPANEL_EMAIL_QUOTA=500
CPANEL_DOMAIN=yourdomain.com

# ============================================================================
# PUSH NOTIFICATIONS (Firebase Cloud Messaging)
# ============================================================================
FCM_SERVER_KEY=your_fcm_server_key_here
