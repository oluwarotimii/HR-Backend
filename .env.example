# Database Configuration
# Option 1: Use connection string (recommended for TiDB Cloud)
DATABASE_URL=mysql://user:password@host:port/database

# Option 2: Use individual variables (traditional)
# Leave DATABASE_URL empty to use these:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hr_management_system

# JWT Configuration
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (Resend)
RESEND_API_KEY=
EMAIL_FROM=

# cPanel Configuration
CPANEL_HOST=bhs108b.superfasthost.cloud
CPANEL_USERNAME=your_cpanel_username
CPANEL_API_TOKEN=your_cpanel_api_token
CPANEL_EMAIL_QUOTA=500
CPANEL_DOMAIN=your_company_domain.com

# Server Configuration
PORT=3000
NODE_ENV=development

# Push Notifications (Firebase Cloud Messaging)
FCM_SERVER_KEY=your_fcm_server_key_here

# Application Configuration
APP_URL=http://localhost:3000
APP_NAME=HR Management System

# Redis Configuration (Optional - set REDIS_ENABLED=false to disable)
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
