{
  "info": {
    "name": "02 - Staff Management & Invitations",
    "description": "Complete staff management including staff CRUD, dynamic fields, and the invitation system. The invitation system allows sending invites to candidates who can then accept and create their accounts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "📧 Staff Invitations",
      "item": [
        {
          "name": "Send Staff Invitation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.environment.set('invitation_id', jsonData.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Smith\",\n  \"personalEmail\": \"jane.smith@gmail.com\",\n  \"phone\": \"+254700000000\",\n  \"roleId\": 2,\n  \"branchId\": 1,\n  \"departmentId\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/staff-invitation",
              "host": ["{{base_url}}"],
              "path": ["api", "staff-invitation"]
            },
            "description": "Send invitation to join the organization. Creates invitation record with token. User will accept via public link."
          },
          "response": [
            {
              "name": "Success - Invitation Sent",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"Invitation sent successfully\",\n  \"data\": {\n    \"email\": \"jane.smith@gmail.com\",\n    \"invitationSent\": true,\n    \"expiresAt\": \"2026-03-05T10:00:00Z\"\n  }\n}"
            },
            {
              "name": "Error - Missing Required Fields",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"First name, last name, personal email, and role ID are required\"\n}"
            },
            {
              "name": "Error - Invalid Email",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"Invalid personal email format\"\n}"
            },
            {
              "name": "Error - Role Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"Role not found\"\n}"
            }
          ]
        },
        {
          "name": "Get All Invitations",
