            "description": "Get all staff invitations with status"
          },
          "response": [
            {
              "name": "Success - Invitations List",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Invitations retrieved successfully\",\n  \"data\": {\n    \"invitations\": [\n      {\n        \"id\": 1,\n        \"email\": \"jane.smith@gmail.com\",\n        \"first_name\": \"Jane\",\n        \"last_name\": \"Smith\",\n        \"phone\": \"+254700000000\",\n        \"status\": \"pending\",\n        \"expires_at\": \"2026-03-05T10:00:00Z\",\n        \"accepted_at\": null,\n        \"created_at\": \"2026-02-26T10:00:00Z\",\n        \"role_name\": \"Manager\",\n        \"branch_name\": \"Nairobi HQ\",\n        \"department_name\": \"IT\",\n        \"invited_by_name\": \"System Administrator\"\n      },\n      {\n        \"id\": 2,\n        \"email\": \"john.doe@gmail.com\",\n        \"first_name\": \"John\",\n        \"last_name\": \"Doe\",\n        \"phone\": \"+254700000001\",\n        \"status\": \"accepted\",\n        \"expires_at\": \"2026-03-06T10:00:00Z\",\n        \"accepted_at\": \"2026-02-27T14:30:00Z\",\n        \"created_at\": \"2026-02-27T10:00:00Z\",\n        \"role_name\": \"Employee\",\n        \"branch_name\": \"Mombasa Branch\",\n        \"department_name\": \"Sales\",\n        \"invited_by_name\": \"HR Manager\"\n      }\n    ]\n  }\n}"
