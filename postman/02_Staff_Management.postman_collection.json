        {
          "name": "Resend Invitation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/staff-invitations/{{invitation_id}}/resend",
              "host": ["{{base_url}}"],
              "path": ["api", "staff-invitations", "{{invitation_id}}", "resend"]
            },
            "description": "Resend invitation email with new token (resets 7-day expiry)"
          },
          "response": [
            {
              "name": "Success - Invitation Resent",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Invitation resent successfully\",\n  \"data\": {\n    \"email\": \"jane.smith@gmail.com\",\n    \"expiresAt\": \"2026-03-05T10:00:00Z\"\n  }\n}"
            },
            {
              "name": "Error - Invitation Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"Invitation not found\"\n}"
            },
            {
              "name": "Error - Already Accepted",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"Cannot resend invitation. Status is accepted\"\n}"
            },
            {
              "name": "Error - Expired",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"Invitation has expired\"\n}"
            }
          ]
        },
        {
          "name": "Cancel Invitation",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/staff-invitations/{{invitation_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "staff-invitations", "{{invitation_id}}"]
            },
            "description": "Cancel a pending invitation"
          },
          "response": [
            {
              "name": "Success - Invitation Cancelled",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Invitation cancelled successfully\"\n}"
            },
            {
              "name": "Error - Not Found or Processed",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"Invitation not found or already processed\"\n}"
            }
          ]
        },
        {
          "name": "Accept Invitation (Public)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"Password123!\",\n  \"confirmPassword\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/staff-invitations/accept/{{invitation_token}}",
              "host": ["{{base_url}}"],
              "path": ["api", "staff-invitations", "accept", "{{invitation_token}}"]
            },
            "description": "Accept invitation and create account. NO authentication required - public endpoint. User sets their password here."
          },
          "response": [
            {
              "name": "Success - Invitation Accepted",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Invitation accepted successfully. You can now login with your work email.\",\n  \"data\": {\n    \"email\": \"jane.smith@tripa.com.ng\"\n  }\n}"
            },
            {
              "name": "Error - Invalid Token",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"success\": false,\n  \"message\": \"Invalid invitation token\"\n}"
            },
            {
              "name": "Error - Already Accepted",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"Invitation has already been accepted\"\n}"
            },
            {
              "name": "Error - Expired",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"Invitation has expired\"\n}"
            },
            {
              "name": "Error - Weak Password",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"message\": \"Password must be at least 8 characters\"\n}"
            }
