{
  "info": {
    "name": "Leave Allocations",
    "description": "API endpoints for managing leave allocations - assign leave days to users",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get My Allocations",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/leave/allocations/my-allocations",
          "host": ["{{base_url}}"],
          "path": ["api", "leave", "allocations", "my-allocations"]
        },
        "description": "Get current user's own leave allocations. No special permission needed."
      },
      "response": []
    },
    {
      "name": "Get All Allocations (Admin/HR)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/leave/allocations?userId=1&leaveTypeId=1&page=1&limit=20",
          "host": ["{{base_url}}"],
          "path": ["api", "leave", "allocations"],
          "query": [
            {
              "key": "userId",
              "value": "1",
              "description": "Filter by user ID"
            },
            {
              "key": "leaveTypeId",
              "value": "1",
              "description": "Filter by leave type ID"
            },
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "20"
            }
          ]
        },
        "description": "Get all leave allocations with filters. Requires 'leave_allocation:read' permission."
      },
      "response": []
    },
    {
      "name": "Get Allocation by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/leave/allocations/1",
          "host": ["{{base_url}}"],
          "path": ["api", "leave", "allocations", "1"]
        },
        "description": "Get specific allocation by ID. Requires 'leave_allocation:read' permission."
      },
      "response": []
    },
    {
      "name": "Create Single Allocation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": 2,\n  \"leave_type_id\": 1,\n  \"allocated_days\": 21,\n  \"cycle_start_date\": \"2026-01-01\",\n  \"cycle_end_date\": \"2026-12-31\",\n  \"carried_over_days\": 0\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/leave/allocations",
          "host": ["{{base_url}}"],
          "path": ["api", "leave", "allocations"]
        },
        "description": "Create a single leave allocation for one user. Requires 'leave_allocation:create' permission."
      },
      "response": []
    },
    {
      "name": "Bulk Allocate - Selected Users",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"leave_type_id\": 7,\n  \"allocated_days\": 30,\n  \"cycle_start_date\": \"2026-01-01\",\n  \"cycle_end_date\": \"2026-12-31\",\n  \"carried_over_days\": 0,\n  \"user_ids\": [2, 3, 4, 5]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/leave/allocations/bulk",
          "host": ["{{base_url}}"],
          "path": ["api", "leave", "allocations", "bulk"]
        },
        "description": "Bulk create allocations for selected users. Provide user_ids array. Requires 'leave_allocation:create' permission."
      },
      "response": []
    },
    {
      "name": "Bulk Allocate - ALL Active Users",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"leave_type_id\": 1,\n  \"allocated_days\": 21,\n  \"cycle_start_date\": \"2026-01-01\",\n  \"cycle_end_date\": \"2026-12-31\",\n  \"carried_over_days\": 0\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/leave/allocations/allocate-all",
          "host": ["{{base_url}}"],
          "path": ["api", "leave", "allocations", "allocate-all"]
        },
        "description": "Create allocations for ALL active users at once. Uses leave_type's days_per_year as reference. Requires 'leave_allocation:create' permission."
      },
      "response": []
    },
    {
      "name": "Update Allocation",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"allocated_days\": 25,\n  \"used_days\": 5,\n  \"carried_over_days\": 2\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/leave/allocations/1",
          "host": ["{{base_url}}"],
          "path": ["api", "leave", "allocations", "1"]
        },
        "description": "Update an existing allocation. Requires 'leave_allocation:update' permission."
      },
      "response": []
    },
    {
      "name": "Delete Allocation",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/leave/allocations/1",
          "host": ["{{base_url}}"],
          "path": ["api", "leave", "allocations", "1"]
        },
        "description": "Delete an allocation. Requires 'leave_allocation:delete' permission."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    }
  ]
}
