              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Senior Manager\",\n  \"description\": \"Senior manager with extended rights\",\n  \"permissions\": [\n    \"staff:read\",\n    \"staff:update\",\n    \"leave:approve\",\n    \"users:read\",\n    \"reports:view\"\n  ]\n}"
