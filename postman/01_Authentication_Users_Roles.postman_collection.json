        },
        {
          "name": "Get Role by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/roles/{{role_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "roles", "{{role_id}}"]
