            "url": {
              "raw": "{{base_url}}/api/roles/{{role_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "roles", "{{role_id}}"]
            },
            "description": "Update role and permissions"
          },
          "response": [
            {
              "name": "Success - Role Updated",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"message\": \"Role updated successfully\",\n  \"data\": {\n    \"role\": {\n      \"id\": 2,\n      \"name\": \"Senior Manager\",\n      \"description\": \"Senior manager with extended rights\",\n      \"updated_at\": \"2026-02-26T10:00:00Z\"\n    },\n    \"permissions\": [\n      \"staff:read\",\n      \"staff:update\",\n      \"leave:approve\",\n      \"users:read\",\n      \"reports:view\"\n    ]\n  }\n}"
            }
          ]
        },
        {
          "name": "Delete Role",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/roles/{{role_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "roles", "{{role_id}}"]
            },
            "description": "Delete role (soft delete)"
          },
          "response": [
            {
