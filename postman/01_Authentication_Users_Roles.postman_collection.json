          "response": [
            {
              "name": "Success - Role Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"success\": true,\n  \"message\": \"Role created successfully\",\n  \"data\": {\n    \"role\": {\n      \"id\": 6,\n      \"name\": \"Supervisor\",\n      \"description\": \"Team supervisor with limited approval rights\",\n      \"created_at\": \"2026-02-26T10:00:00Z\"\n    },\n    \"permissions\": [\n      \"staff:read\",\n      \"leave:read\",\n      \"leave:approve\",\n      \"attendance:read\"\n    ]\n  }\n}"
